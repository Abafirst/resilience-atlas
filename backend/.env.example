# ==============================================================================
# Resilience Atlas — Backend Environment Variables
# ==============================================================================
#
# HOW TO USE
# ----------
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values where indicated.
# 3. NEVER commit .env to git — it is already in .gitignore.
#
# This file is safe to commit because it contains only placeholder values
# and comments, not real secrets.
# ==============================================================================


# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------

# Port the Express server listens on (default: 3000)
PORT=3000

# Runtime environment.  Use "development" locally; Railway sets this to
# "production" automatically.
NODE_ENV=development


# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------

# MongoDB connection string (optional — app runs without it but DB-backed
# features such as saved assessments and teams will be disabled).
# Format: mongodb+srv://<user>:<password>@<cluster>/<dbName>?retryWrites=true&w=majority
MONGODB_URI=


# ------------------------------------------------------------------------------
# Authentication — JWT (legacy / fallback)
# ------------------------------------------------------------------------------

# Secret used to sign and verify HS256 JWTs issued by the backend.
# Required for any endpoint that uses the authenticateJWT middleware when
# Auth0 RS256 validation is not configured.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=


# ------------------------------------------------------------------------------
# Authentication — Auth0 (recommended)
# ------------------------------------------------------------------------------
# The frontend SPA fetches these values at runtime from GET /config, which
# reads them from the backend environment.  Setting them here means you do NOT
# need matching VITE_AUTH0_* variables in client/.env.local for local dev.

# Your Auth0 tenant domain (e.g. your-tenant.us.auth0.com)
AUTH0_DOMAIN=

# Auth0 application Client ID (single-page or regular web application)
AUTH0_CLIENT_ID=

# Auth0 API audience / identifier (optional — only needed if you request
# access tokens for a protected backend API)
AUTH0_AUDIENCE=

# Long random secret used by express-openid-connect for server-side OIDC
# sessions.  This is NOT your Auth0 Client Secret — it is an app-level secret.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUTH0_SECRET=


# ------------------------------------------------------------------------------
# Payments — Stripe
# ------------------------------------------------------------------------------

# Publishable key — safe to expose to the frontend (returned by GET /config).
# Starts with pk_test_ (test) or pk_live_ (production).
STRIPE_PUBLISHABLE_KEY=

# Secret key — NEVER expose this to the browser.
# Starts with sk_test_ (test) or sk_live_ (production).
STRIPE_SECRET_KEY=

# Webhook signing secret — used to verify Stripe webhook payloads.
# Copy from the Stripe Dashboard → Developers → Webhooks → your endpoint.
STRIPE_WEBHOOK_SECRET=

# (Optional) Stripe Price ID for one-time purchases.
# If set, overrides inline price_data in checkout sessions.
STRIPE_ONE_TIME_PRICE_ID=

# (Optional) Legacy Stripe Price ID — used only if STRIPE_ONE_TIME_PRICE_ID
# is not set.  Prefer STRIPE_ONE_TIME_PRICE_ID for new setups.
STRIPE_PRICE_ID=


# ------------------------------------------------------------------------------
# Email — SendGrid SMTP relay (Nodemailer)
# ------------------------------------------------------------------------------

# SMTP server hostname
SMTP_HOST=smtp.sendgrid.net

# SMTP port (587 = STARTTLS, 465 = SSL)
SMTP_PORT=587

# SendGrid requires the literal string "apikey" as the username.
SMTP_USER=apikey

# Your SendGrid API key (starts with SG.)
SMTP_PASS=

# (Optional) Set to "true" to force TLS instead of STARTTLS.
# Leave blank for port 587 (STARTTLS is negotiated automatically).
SMTP_SECURE=

# (Optional) Override the From address used in outgoing emails.
# Defaults to the branding.company.email value in backend/config/branding.js.
EMAIL_FROM=


# ------------------------------------------------------------------------------
# Application URLs
# ------------------------------------------------------------------------------

# Public base URL of the application (required for Stripe success/cancel
# redirect URLs and Auth0 callback URLs).
# e.g. http://localhost:3000 for local dev, https://yourdomain.com in prod.
APP_URL=http://localhost:3000

# Allowed CORS origin for the frontend (required in production).
# For local dev the frontend runs on http://localhost:5173 (proxied via Vite).
CORS_ORIGIN=http://localhost:5173


# ------------------------------------------------------------------------------
# Error Monitoring — Sentry (optional)
# ------------------------------------------------------------------------------

# Sentry DSN.  Leave blank to disable Sentry.
SENTRY_DSN=

# Fraction of transactions to trace (0.0 – 1.0).  Default: 0.1 in production.
SENTRY_TRACES_SAMPLE_RATE=


# ------------------------------------------------------------------------------
# Admin
# ------------------------------------------------------------------------------

# Secret header value required by POST /admin/seed-resources.
# Generate a strong random string and keep it server-only.
ADMIN_SEED_SECRET=

# Admin email address used for seeding or notification purposes.
ADMIN_EMAIL=


# ------------------------------------------------------------------------------
# Branding overrides (optional)
# ------------------------------------------------------------------------------
# All of these have sensible defaults in backend/config/branding.js.
# Override only if you need to white-label or use a custom domain/email.

COMPANY_DOMAIN=
COMPANY_EMAIL=
SUPPORT_EMAIL=
LINKEDIN_URL=
TWITTER_URL=
FACEBOOK_URL=
YOUTUBE_URL=


# ------------------------------------------------------------------------------
# Logging (optional)
# ------------------------------------------------------------------------------

# Winston log level.  One of: error, warn, info, http, verbose, debug, silly.
# Defaults to "info".
LOG_LEVEL=info


# ------------------------------------------------------------------------------
# Debug flags (optional)
# ------------------------------------------------------------------------------

# Set to "true" to enable verbose Stripe debug logging.
# Non-production environments always enable this automatically.
DEBUG_STRIPE=
