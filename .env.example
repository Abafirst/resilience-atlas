# .env.example

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Database URL
DATABASE_URL="postgres://user:password@localhost:5432/database"

# MongoDB Connection URI
MONGODB_URI="mongodb://localhost:27017/resilience-atlas"

# JWT Secret
JWT_SECRET="your_jwt_secret"

# Session Secret
SESSION_SECRET="your_session_secret"

# Yahoo Email
YAHOO_EMAIL="your_email@yahoo.com"

# Yahoo App Password
YAHOO_APP_PASSWORD="your_yahoo_app_password"

# Stripe Publishable Key
STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"

# Stripe Secret Key
STRIPE_SECRET_KEY="your_stripe_secret_key"

# Stripe Webhook Secret
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── Authentication ────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
SESSION_SECRET=change_this_to_another_long_random_string

# ── Database ──────────────────────────────────────────────────
# If your MongoDB Atlas password contains special characters (@, !, #, $, %, &, etc.)
# they MUST be URL-encoded in the connection string.
# Run:  node backend/utils/encodeMongoPassword.js 'your-raw-password'
# See:  docs/MONGODB_URL_ENCODING.md for a full encoding reference.
MONGODB_URI=mongodb://localhost:27017/resilience-atlas

# ── Email (Yahoo Mail) ────────────────────────────────────────
YAHOO_EMAIL=your_email@yahoo.com
YAHOO_APP_PASSWORD=your_yahoo_app_password

# ── Stripe ────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ── OpenClaw / Telegram ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
OPENCLAW_PORT=3001

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info

# ── Queue (Redis / BullMQ) ────────────────────────────────────
# Required for asynchronous report generation.
# If not set, report generation falls back to a no-op (scores are still returned immediately).
REDIS_URL=redis://localhost:6379
