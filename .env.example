# .env.example

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Database URL
DATABASE_URL="postgres://user:password@localhost:5432/database"

# MongoDB Connection URI
MONGODB_URI="mongodb://localhost:27017/resilience-atlas"

# JWT Secret
JWT_SECRET="your_jwt_secret"

# Session Secret
SESSION_SECRET="your_session_secret"

# Yahoo Email
YAHOO_EMAIL="your_email@yahoo.com"

# Yahoo App Password
YAHOO_APP_PASSWORD="your_yahoo_app_password"

# Stripe Publishable Key
STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"

# Stripe Secret Key
STRIPE_SECRET_KEY="your_stripe_secret_key"

# Stripe Webhook Secret
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"
APP_URL=http://localhost:3000
# APP_URL is used to build Stripe Checkout success_url and cancel_url.
# Set this to your public domain so Stripe redirects users back to the
# correct origin after payment.
# Production example:  APP_URL=https://theresilienceatlas.com
# Staging example:     APP_URL=https://resilience-atlas-staging.up.railway.app
CORS_ORIGIN=http://localhost:3000

# ── Authentication ────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
SESSION_SECRET=change_this_to_another_long_random_string

# ── Database ──────────────────────────────────────────────────
# If your MongoDB Atlas password contains special characters (@, !, #, $, %, &, etc.)
# they MUST be URL-encoded in the connection string.
# Run:  node backend/utils/encodeMongoPassword.js 'your-raw-password'
# See:  docs/MONGODB_URL_ENCODING.md for a full encoding reference.
MONGODB_URI=mongodb://localhost:27017/resilience-atlas

# ── Email (Yahoo Mail) ────────────────────────────────────────
YAHOO_EMAIL=your_email@yahoo.com
YAHOO_APP_PASSWORD=your_yahoo_app_password

# ── Stripe ────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ── OpenClaw / Telegram ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
OPENCLAW_PORT=3001

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info

# ── Queue (Redis / BullMQ) ────────────────────────────────────
# Required for asynchronous report generation.
# If not set, report generation falls back to a no-op (scores are still returned immediately).
REDIS_URL=redis://localhost:6379

# ── Business Tier ─────────────────────────────────────────────
# Stripe Price IDs for the business tier (create in your Stripe dashboard).
# The price ID determines per-seat pricing for team subscriptions.
STRIPE_BUSINESS_PRICE_ID=price_your_business_price_id
# Minimum number of seats required for a business subscription.
BUSINESS_MIN_SEATS=5
# Price per seat in USD cents (e.g. 4900 = $49.00)
BUSINESS_SEAT_PRICE_CENTS=4900

# ── Branding ──────────────────────────────────────────────────
COMPANY_DOMAIN=theresilienceatlas.com
COMPANY_EMAIL=janeen@theresilienceatlas.com
SUPPORT_EMAIL=janeen@theresilienceatlas.com
LINKEDIN_URL=https://www.linkedin.com/company/theresilienceatlas
TWITTER_URL=https://x.com/atlasresilience
FACEBOOK_URL=https://www.facebook.com/profile.php?id=100076220534241
