# .env.example

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Database URL
DATABASE_URL="postgres://user:password@localhost:5432/database"

# MongoDB Connection URI
MONGODB_URI="mongodb://localhost:27017/resilience-atlas"

# JWT Secret
JWT_SECRET="your_jwt_secret"

# Session Secret
SESSION_SECRET="your_session_secret"

# Yahoo Email
# YAHOO_EMAIL="your_email@yahoo.com"

# Yahoo App Password
# YAHOO_APP_PASSWORD="your_yahoo_app_password"

# SendGrid SMTP relay (recommended)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key

# Stripe Publishable Key
STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"

# Stripe Secret Key
STRIPE_SECRET_KEY="your_stripe_secret_key"

# Stripe Webhook Secret
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"
APP_URL=http://localhost:3000
# APP_URL is used to build Stripe Checkout success_url and cancel_url.
# Set this to your public domain so Stripe redirects users back to the
# correct origin after payment.
# Production example:  APP_URL=https://theresilienceatlas.com
# Staging example:     APP_URL=https://resilience-atlas-staging.up.railway.app
CORS_ORIGIN=http://localhost:3000

# ── Authentication ────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
SESSION_SECRET=change_this_to_another_long_random_string

# ── Database ──────────────────────────────────────────────────
# If your MongoDB Atlas password contains special characters (@, !, #, $, %, &, etc.)
# they MUST be URL-encoded in the connection string.
# Run:  node backend/utils/encodeMongoPassword.js 'your-raw-password'
# See:  docs/MONGODB_URL_ENCODING.md for a full encoding reference.
MONGODB_URI=mongodb://localhost:27017/resilience-atlas

# ── Email (SendGrid SMTP) ─────────────────────────────────────
# SendGrid SMTP relay via Nodemailer.
# SMTP_USER must be the literal string "apikey".
# SMTP_PASS is your SendGrid API key (starts with SG.).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key

# ── Admin / Notification Email ────────────────────────────────
# This address receives Atlas Team Enterprise inquiry notifications
# from the /team.html inquiry form (POST /api/growth/team-lead).
# Must be set to ensure every Enterprise inquiry triggers an email.
# Falls back to COMPANY_EMAIL → SUPPORT_EMAIL → EMAIL_FROM.
ADMIN_EMAIL=admin@your-domain.com

# ── Stripe ────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ── OpenClaw / Telegram ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
OPENCLAW_PORT=3001

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info

# ── Queue (Redis / BullMQ) ────────────────────────────────────
# Required for asynchronous report generation.
# If not set, report generation falls back to a no-op (scores are still returned immediately).
REDIS_URL=redis://localhost:6379

# ── Business Tier ─────────────────────────────────────────────
# Stripe Price IDs for the business tier (create in your Stripe dashboard).
# The price ID determines per-seat pricing for team subscriptions.
STRIPE_BUSINESS_PRICE_ID=price_your_business_price_id
# Minimum number of seats required for a business subscription.
BUSINESS_MIN_SEATS=5
# Price per seat in USD cents (e.g. 4900 = $49.00)
BUSINESS_SEAT_PRICE_CENTS=4900

# ── Branding ──────────────────────────────────────────────────
COMPANY_DOMAIN=theresilienceatlas.com
COMPANY_EMAIL=janeen@theresilienceatlas.com
SUPPORT_EMAIL=janeen@theresilienceatlas.com
LINKEDIN_URL=https://www.linkedin.com/company/theresilienceatlas
TWITTER_URL=https://x.com/atlasresilience
FACEBOOK_URL=https://www.facebook.com/profile.php?id=100076220534241

# ── Auth0 (server-side) ───────────────────────────────────────
# Used by the backend to redirect /login and /register to Auth0 Universal Login.
# Copy the values from your Auth0 Application settings.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
# Callback URL after Auth0 login — defaults to the server origin when not set.
AUTH0_REDIRECT_URI=https://your-production-domain.com

# ── React Client build-time variables (Vite) ─────────────────────────────────
# These values are baked into the JavaScript bundle at build time by Vite.
# For Docker/Railway deployments, pass them as Docker build ARGs:
#   docker build \
#     --build-arg VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com \
#     --build-arg VITE_AUTH0_CLIENT_ID=your-client-id \
#     ...
# For local development, copy client/.env.example to client/.env and fill in
# values there (Vite reads client/.env automatically during `npm run dev`).
# WARNING: Missing VITE_AUTH0_DOMAIN or VITE_AUTH0_CLIENT_ID will cause the
# React app to throw an error on startup and display a blank/broken page.
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_REDIRECT_URI=https://your-production-domain.com
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
