# Auth0 configuration for Vite/React (local development)
#
# In production the React SPA fetches Auth0 domain and client ID at runtime
# from the server's /config endpoint (AUTH0_DOMAIN and AUTH0_CLIENT_ID env
# vars on the server).  You only need to set VITE_AUTH0_DOMAIN /
# VITE_AUTH0_CLIENT_ID here for LOCAL DEVELOPMENT where the server may not
# be running or may not have those env vars set.
#
# Copy this file to .env.local and fill in your Auth0 values for local dev.
# All variables must be prefixed with VITE_ so Vite exposes them to the browser.
# See: https://vitejs.dev/guide/env-and-mode.html

# Your Auth0 application domain (e.g. your-tenant.us.auth0.com)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com

# Your Auth0 application Client ID
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# (Optional) API audience / identifier configured in Auth0
# Required if you want to obtain access tokens for a backend API
VITE_AUTH0_AUDIENCE=https://your-api-identifier

# (Optional) Override the callback URL after login.
# Defaults to window.location.origin when not set.
VITE_AUTH0_REDIRECT_URI=http://localhost:5173
