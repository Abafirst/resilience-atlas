# ==============================================================================
# Resilience Atlas — Frontend (Vite/React) Environment Variables
# ==============================================================================
#
# HOW TO USE
# ----------
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in your real values where indicated.
# 3. NEVER commit .env.local to git — it is already in .gitignore.
#
# All variables MUST be prefixed with VITE_ so Vite exposes them in the
# browser via import.meta.env.  See: https://vitejs.dev/guide/env-and-mode.html
#
# IMPORTANT — TWO SOURCES OF CONFIGURATION
# -----------------------------------------
# The SPA has TWO ways to receive runtime config values:
#
#   1. RUNTIME (recommended for local dev):
#      The backend exposes GET /config, which returns Auth0 and Stripe config
#      read from backend/.env.  If the backend is running on localhost:3000 and
#      Vite's proxy is forwarding /config → backend (see client/vite.config.js),
#      you do NOT need any VITE_AUTH0_* or VITE_STRIPE_* variables here.
#      Set them in backend/.env instead (see backend/.env.example).
#
#   2. BUILD-TIME FALLBACK (used when /config returns null values):
#      main.jsx falls back to VITE_AUTH0_DOMAIN / VITE_AUTH0_CLIENT_ID when
#      the runtime /config response is empty.  Set these here only if the
#      backend is not available during local development.
#
# ==============================================================================


# ------------------------------------------------------------------------------
# App version (optional)
# ------------------------------------------------------------------------------

# Displayed as window._spaVersion for debugging.  Defaults to "dev".
VITE_APP_VERSION=dev


# ------------------------------------------------------------------------------
# Auth0 — build-time fallback (optional for local dev)
# ------------------------------------------------------------------------------
# In production the SPA fetches these from the backend GET /config endpoint.
# For local development, set them in backend/.env instead.
# Only set these here if the backend is unavailable during local development.

# Your Auth0 tenant domain (e.g. your-tenant.us.auth0.com)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com

# Your Auth0 application Client ID
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# (Optional) API audience / identifier configured in Auth0.
# Required if you want to obtain access tokens for a protected backend API.
VITE_AUTH0_AUDIENCE=https://your-api-identifier

# (Optional) Override the callback URL after login.
# On native Capacitor builds the app uses capacitor://localhost automatically.
# This value applies to web builds; web fallback defaults to window.location.origin when not set.
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/callback


# ------------------------------------------------------------------------------
# Stripe — build-time fallback (optional for local dev)
# ------------------------------------------------------------------------------
# In production the SPA fetches the publishable key from GET /config.
# For local development, set STRIPE_PUBLISHABLE_KEY in backend/.env instead.
# Only set this here if the backend is unavailable during local development.

# Stripe publishable key (starts with pk_test_ or pk_live_).
VITE_STRIPE_PUBLISHABLE_KEY=
