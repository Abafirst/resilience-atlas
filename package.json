    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-rate-limit": "^5.3.0",
    "helmet": "^4.6.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^3.6.9",
    "mongoose": "^9.2.4",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.18.0",
    "puppeteer": "^24.38.0",
    "stripe": "^14.0.0",
    "winston": "^3.19.0"
