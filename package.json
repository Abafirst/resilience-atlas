{
  "name": "resilience-atlas",
  "version": "1.0.0",
  "description": "A resilience assessment platform",
  "main": "backend/server.js",
  "scripts": {
    "test": "jest --forceExit",
    "start": "node backend/server.js",
    "start:prod": "npm run build && node backend/server.js",
    "dev": "nodemon backend/server.js",
    "build": "cd client && npm install && npm run build",
    "dev-open": "fuser -k 3000/tcp 2>/dev/null; nodemon backend/server.js & sleep 3; powershell.exe start http://localhost:3000",
    "social:build": "node scripts/render-social.js",
    "generate-brand": "node scripts/generate-brand-assets.js",
    "seed:resources": "node scripts/seed-resources.js"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.16.0",
    "@dabh/diagnostics": "2.0.8",
    "@resvg/resvg-js": "^2.6.2",
    "@sendgrid/mail": "^8.1.6",
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^10.0.0",
    "express": "^4.22.1",
    "express-openid-connect": "^2.19.4",
    "express-rate-limit": "^5.3.0",
    "glob": "^13.0.6",
    "helmet": "^4.6.0",
    "inflight": "^1.0.6",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "mongodb": "^3.6.9",
    "mongoose": "^9.2.4",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.18.0",
    "puppeteer": "^24.38.0",
    "stripe": "^14.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "glob": "^11.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.1.14",
    "sharp": "^0.34.5",
    "supertest": "^6.1.6"
  }
}
